{
  "manifest_version": 3,
  "name": "TriAuto des Téléchargements",
  "version": "1.3.1",
  "description": "Classe automatiquement les fichiers téléchargés par type avec une interface moderne et des options avancées.",
  "permissions": ["downloads", "storage", "notifications"],
  "host_permissions": ["file://*/*"],
  "icons": {
    "16": "src/assets/icon.png",
    "48": "src/assets/icon.png",
    "128": "src/assets/icon.png"
  },
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "action": {
    "default_icon": "src/assets/icon.png",
    "default_title": "TriAuto",
    "default_popup": "src/popup/popup.html"
  }
}
